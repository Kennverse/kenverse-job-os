# KenVerse Job OS — Environment Variables
# Copy this to .env and edit as needed.
# DO NOT commit .env to version control.

# Development mode flag
NODE_ENV=development

# Optional: override the ingestion cron schedule
# Default: every 6 hours ("0 */6 * * *")
# INGESTION_SCHEDULE="0 */6 * * *"

# Optional: if you want to pre-set OpenAI key in dev without using the UI
# In production the key is stored encrypted via electron-store
# OPENAI_API_KEY=sk-your-key-here

# Optional: Adzuna API credentials (for Adzuna job source adapter)
# ADZUNA_APP_ID=your_app_id
# ADZUNA_API_KEY=your_api_key

# Optional: Reed API key (for UK jobs via Reed adapter)
# REED_API_KEY=your_api_key
