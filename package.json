{
  "name": "kenverse-job-os",
  "version": "1.0.0",
  "description": "KenVerse Job Application OS — Personal job search and application desktop system",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "vite build --config vite.main.config.ts --watch",
    "dev:renderer": "vite --config vite.config.ts",
    "electron": "wait-on dist/main/index.js && electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "vite build --config vite.main.config.ts",
    "build:renderer": "vite build --config vite.config.ts",
    "package": "npm run build && electron-builder build --win",
    "package:dir": "npm run build && electron-builder build --win --dir",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/main/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx}"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^9.6.0",
    "drizzle-orm": "^0.31.4",
    "electron-store": "^10.0.0",
    "openai": "^4.52.0",
    "rss-parser": "^3.13.0",
    "docx": "^8.5.0",
    "pdf-lib": "^1.17.1",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0",
    "crypto-js": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "zustand": "^4.5.4",
    "date-fns": "^3.6.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.22.8",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vite-plugin-electron": "^0.28.7",
    "vitest": "^2.0.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "extends": "./electron-builder.config.js"
  }
}
